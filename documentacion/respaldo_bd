CREATE VIEW public.vista_productos_stock AS
 SELECT p.id_producto,
    p.codigo,
    p.nombre,
    p.descripcion,
    p.precio,
    c.nombre AS categoria,
    a.codigo AS codigo_anaquel,
    a.nombre AS anaquel,
    a.ubicacion,
    i.stock_actual,
    i.stock_minimo,
        CASE
            WHEN (i.stock_actual <= i.stock_minimo) THEN 'Stock bajo'::text
            ELSE 'Stock disponible'::text
        END AS estado_stock
   FROM (((public.productos p
     JOIN public.categorias c ON ((p.id_categoria = c.id_categoria)))
     LEFT JOIN public.anaqueles a ON ((p.id_anaquel = a.id_anaquel)))
     LEFT JOIN public.inventario i ON ((p.id_producto = i.id_producto)))
  WHERE (p.estado = true);


